{
  "name": "smart-retail-pos-desktop-next",
  "version": "0.1.0",
  "description": "Electron + React migration shell for Smart Retail POS",
  "author": "Rashmika Madela",
  "license": "UNLICENSED",
  "homepage": "https://github.com/RashmikaMadaela/smart-retail-pos",
  "repository": {
    "type": "git",
    "url": "https://github.com/RashmikaMadaela/smart-retail-pos.git"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/main.cjs",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "build:renderer": "vite build",
    "build:electron": "tsup --config tsup.config.ts",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "electron dist-electron/main.cjs",
    "smoke": "npm run check && npm run test && npm run build",
    "dist:nsis": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false BUILD_TARGET=nsis electron-builder --win nsis --publish never",
    "dist:portable": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false BUILD_TARGET=portable electron-builder --win portable --publish never",
    "dist": "npm run dist:nsis && npm run dist:portable",
    "pretest": "npm run rebuild:native:node",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.smartretail.posnext",
    "productName": "Smart Retail POS Next",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../database",
        "to": "database",
        "filter": [
          "pos.db"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "SmartRetailPOSNext-${version}-${arch}-${env.BUILD_TARGET}.${ext}"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "displayLanguageSelector": false
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.49",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.3"
  }
}
